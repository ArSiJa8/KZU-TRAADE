<template>
  <div class="container">
    <NuxtLink to="/chat" class="back">← Zurück</NuxtLink>

    <h2>Chat zu {{ image }}</h2>

    <img :src="`/uploads/${image}`" class="preview" />

    <div class="chat-box">
      <div class="messages">
        <div v-for="msg in messages" :key="msg.time" class="message">
          <strong>{{ msg.user }}:</strong> {{ msg.message }}
        </div>
      </div>

      <input v-model="newMessage" placeholder="Nachricht schreiben…" @keyup.enter="send" />
      <button @click="send">Senden</button>
    </div>
  </div>
</template>

<script setup>
const route = useRoute()
const image = route.params.image

const messages = ref([])
const newMessage = ref('')

async function loadChat() {
  messages.value = await $fetch('/api/chat', {
    method: 'GET',
    query: { file: image }
  })
}

async function send() {
  if (!newMessage.value) return

  await $fetch('/api/chat', {
    method: 'POST',
    body: {
      file: image,
      message: newMessage.value,
      user: 'Gast'
    }
  })

  newMessage.value = ''
  loadChat()
}

onMounted(loadChat)
</script>

<style scoped>
.container { max-width: 600px; margin: auto; padding: 20px; }
.preview { width: 100%; border-radius: 10px; margin-bottom: 20px; }
.chat-box { background: #f3f3f3; padding: 15px; border-radius: 10px; }
.messages { max-height: 300px; overflow-y: auto; margin-bottom: 10px; }
.message { padding: 5px 0; border-bottom: 1px solid #ddd; }
.back { display: inline-block; margin-bottom: 20px; }
</style>
