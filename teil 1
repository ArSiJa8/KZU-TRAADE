<template>
  <div class="container">
    <h2>Foto hochladen</h2>

    <input type="file" @change="previewImage" accept="image/*" />
    <img v-if="preview" :src="preview" class="preview" />

    <button @click="upload">Bild veröffentlichen</button>

    <div class="gallery">
      <div v-for="img in images" :key="img" class="item">
        <img :src="`/uploads/${img}`" alt="User Foto" />
        <button class="delete-btn" @click="remove(img)">Löschen</button>
      </div>
    </div>
  </div>
</template>

<script setup lang="ts">
import { onMounted, ref } from 'vue'

type ApiResult = {
  success?: boolean
  error?: string
}

type UploadResult = ApiResult & {
  file?: string
}

type ListResult = ApiResult & {
  images?: string[]
}

const preview = ref<string | null>(null)
const file = ref<File | null>(null)
const images = ref<string[]>([])
const isUploading = ref(false)
const isLoading = ref(false)

function previewImage(event: Event) {
  const target = event.target as HTMLInputElement
  const selectedFile = target.files?.[0]

  if (!selectedFile) {
    return
  }

  file.value = selectedFile

  if (preview.value) {
    URL.revokeObjectURL(preview.value)
  }

  preview.value = URL.createObjectURL(selectedFile)
}

async function upload() {
  if (!file.value || isUploading.value) {
    return
  }

  isUploading.value = true

  try {
    const form = new FormData()
    form.append('file', file.value)

    const res = await $fetch<UploadResult>('/api/upload', {
      method: 'POST',
      body: form
    })

    if (res.error) {
      alert(res.error)
      return
    }

    file.value = null

    if (preview.value) {
      URL.revokeObjectURL(preview.value)
      preview.value = null
    }

    await loadImages()
  } finally {
    isUploading.value = false
  }
}

async function remove(name: string) {
  const res = await $fetch<ApiResult>('/api/delete', {
    method: 'POST',
    body: {
      file: name
    }
  })

  if (res.error) {
    alert(res.error)
    return
  }

  await loadImages()
}

async function loadImages() {
  isLoading.value = true

  try {
    const res = await $fetch<ListResult>('/api/images')

    if (res.error) {
      alert(res.error)
      return
    }

    images.value = res.images ?? []
  } finally {
    isLoading.value = false
  }
}

onMounted(loadImages)
</script>

<template>
  <main class="container">
    <section class="upload-card">
      <h1>KZU Trade</h1>
      <h2>Foto hochladen</h2>

      <label class="file-input">
        <span>Bild auswählen</span>
        <input
          type="file"
          accept="image/*"
          @change="previewImage"
        >
      </label>

      <img
        v-if="preview"
        :src="preview"
        class="preview"
        alt="Vorschau des ausgewählten Bildes"
      >

      <button
        class="primary-btn"
        :disabled="!file || isUploading"
        @click="upload"
      >
        {{ isUploading ? 'Wird hochgeladen...' : 'Bild veröffentlichen' }}
      </button>
    </section>

    <section class="gallery-section">
      <h2>Galerie</h2>

      <p v-if="isLoading">
        Bilder werden geladen...
      </p>

      <p v-else-if="images.length === 0" class="empty">
        Noch keine Bilder vorhanden.
      </p>

      <div v-else class="gallery">
        <article
          v-for="img in images"
          :key="img"
          class="item"
        >
          <img
            :src="`/uploads/${img}`"
            alt="User Foto"
          >
          <button
            class="delete-btn"
            @click="remove(img)"
          >
            Löschen
          </button>
        </article>
      </div>
    </section>
  </main>
</template>

